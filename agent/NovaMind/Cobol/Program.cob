Hier ist der COBOL-Code:

IDENTIFICATION DIVISION.
PROGRAM-ID. NVM.

DATA DIVISION.

WORKING-STORAGE SECTION.

01  INPUT-LINE    PIC X(80) VALUE SPACE.
02  RESULT        PIC X(255) VALUE SPACE.
03  LANG          PIC X(2) VALUE 'de'.
04  FILE-NAME      PIC X(30) VALUE SPACE.
05  TARGET-DIR    PIC X(30) VALUE 'Cobol'.
06  ORIGINAL-FILE-NAME  PIC X(30) VALUE SPACE.
07  NEW-FILE-NAME   PIC X(30) VALUE SPACE.

PROCEDURE DIVISION.

MAIN-PROGRAM.

    PERFORM ACCEPT-INP
    PERFORM PROCESS-INPUT

STOP RUN.

ACCEPT-INP.
    ACCEPT INPUT-LINE

PROCESS-INPUT.
    IF INPUT-LINE EQ 'exit' THEN
        STOP RUN
    ELSE
        PERFORM HANDLE-COMMAND
    END-IF

HANDLE-COMMAND.
    IF INPUT-LINE STARTS WITH '/COBOL'
        THEN
            PERFORM COBOL-HANDLER
        ELSE
            PERFORM STANDARD-HANDLER
    END-IF

COBOL-HANDLER.
    MOVE SPACE TO RESULT
    STRING 'Analyzing ' INPUT-LINE DELIMITED BY SIZE
         INTO RESULT
    STRING ' and generating COBOL code...' DELIMITED BY SIZE
         AFTER RESULT
    PERFORM WRITE-COBOL-FILE

WRITE-COBOL-FILE.
    STRING 'File successfully saved under: ' 
           TARGET-DIR NEW-FILE-NAME DELIMITED BY SIZE
         INTO RESULT
    DISPLAY RESULT

STD-HANDLER.
    IF INPUT-LINE STARTS WITH '/'
        THEN
            PERFORM HANDLE-COMMAND-ROUTER
        ELSE
            MOVE INPUT-LINE TO RESULT
            STRING 'Llama: ' RESULT DELIMITED BY SIZE
                 INTO RESULT
            DISPLAY RESULT
    END-IF

HANDLE-COMMAND-ROUTER.
    IF INPUT-LINE EQ '/help'
        THEN
            PERFORM HELP-HANDLER
        ELSE
            PERFORM STANDARD-HANDLER
    END-IF

HELP-HANDLER.
    STRING 'Help command...' DELIMITED BY SIZE
         INTO RESULT
    DISPLAY RESULT

STD-HANDLER.
    MOVE INPUT-LINE TO RESULT
    STRING 'unknown command' DELIMITED BY SIZE
         AFTER RESULT
    DISPLAY RESULT